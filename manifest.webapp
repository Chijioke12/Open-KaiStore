{
  "name": "Open-KaiStore",
  "version": "1.0.0",
  "origin": "app://open-kaistore.chijioke.com",
  "description": "A decentralized app store for KaiOS",
  "launch_path": "/index.html",
  "type": "privileged",
  "developer": {
    "name": "Open-KaiStore Team",
    "url": "https://github.com/open-kaistore"
  },
  "permissions": {
    "webapps-manage": {
      "description": "Required to install and manage apps"
    },
    "systemXHR": {
      "description": "Required to fetch app registry and binaries from GitHub"
    }
  },
  "default_locale": "en-US",
  "icons": {
    "56": "/icons/icon-56.png",
    "112": "/icons/icon-112.png"
  }
}
